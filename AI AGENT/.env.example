# OpenClaw Operation Environment Variables
# Copy to .env and fill in actual values

# Remote server
REMOTE_HOST=100.72.155.61
REMOTE_USER=hqj
OPENCLAW_BASE=/home/hqj/.openclaw

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Gateway Auth
GATEWAY_AUTH_TOKEN=your_gateway_token_here

# Jira API Token (for cron job reports and onepay agent)
JIRA_TOKEN=your_jira_token_here

# ELK Credentials (for onepay agent ELK queries)
ELK_USER=elastic
ELK_PASS=your_elk_password_here

# OnePay platform secrets (base64-encoded onepay-platforms.json)
ONEPAY_PLATFORMS_JSON=your_base64_encoded_json_here

# OpenAI API Keys (per-agent, injected to auth-profiles.json)
# OPENAI_API_KEY_ONEPAY is shared by onepay, onepay-internal, onepay-external
OPENAI_API_KEY_MAIN=your_openai_api_key_here
OPENAI_API_KEY_CAMS=your_openai_api_key_here
OPENAI_API_KEY_ONEPAY=your_openai_api_key_here
OPENAI_API_KEY_GB_OL=your_openai_api_key_here
OPENAI_API_KEY_CODEREVIE_OL=your_openai_api_key_here

# ELK MCP API Token (for gb-ol agent's elk-log-query skill)
ELK_MCP_TOKEN=your_elk_mcp_token_here

# GitHub App Private Key (base64-encoded .pem for openclaw-reviewer bot)
REVIEWER_APP_PRIVATE_KEY_BASE64=your_base64_encoded_pem_here

# Standby server (HA failover)
STANDBY_HOST=100.85.165.67
STANDBY_USER=hqj
# STANDBY_PASSWORD is set via SSHPASS_STANDBY or GitHub secret

# Watchdog Telegram notifications
WATCHDOG_BOT_TOKEN=your_bot_token_here
WATCHDOG_CHAT_ID=your_chat_id_here

# Settlement Bot
TG_BOT_TOKEN_SETTLEMENT=your_settlement_bot_token_here
ES_HOST_SETTLEMENT=your_es_host_here
ES_PASS_SETTLEMENT=your_es_password_here
TG_FORWARD_GROUP_SETTLEMENT=-1234567890
SETTLEMENT_TG_GROUP=-1234567890
OPENAI_API_KEY_SETTLEMENT=your_openai_api_key_here
